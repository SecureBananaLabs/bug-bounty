{
  "root": true,
  "env": {
    "node": true,
    "es2021": true
  },
  "extends": [
    "eslint:recommended"
  ],
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "overrides": [
    {
      "files": [
        "apps/web/**/*.{js,jsx,ts,tsx}"
      ],
      "env": {
        "browser": true
      }
    },
    {
      "files": [
        "packages/ui/**/*.{js,jsx,ts,tsx}"
      ],
      "env": {
        "browser": true
      }
    }
  ],
  "ignorePatterns": [
    "node_modules",
    "dist",
    "build",
    ".next"
  ]
}
