# Copy this file to .env.benchmark at the repository root for local overrides.

# Leave empty to start the local Express API on an ephemeral loopback port.
BENCHMARK_TARGET_URL=

# Local smoke defaults are intentionally small for CI. Override for larger manual runs.
BENCHMARK_DURATION_SECONDS=2
BENCHMARK_CONNECTIONS=4
BENCHMARK_TTFB_SAMPLES=3

# Used to sign the dedicated benchmark admin token for protected endpoints.
JWT_SECRET=development-secret

# Optional output directory.
BENCHMARK_OUTPUT_DIR=benchmarks/results
