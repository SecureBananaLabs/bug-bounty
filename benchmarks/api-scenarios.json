      "rating": 5,
      "comment": "Clear delivery, strong communication, and reliable handoff documentation."
    }
  },
  {
    "name": "messages.list",
    "method": "GET",
    "path": "/api/messages"
  },
  {
    "name": "messages.create",
    "method": "POST",
