      "budgetMin": 1500,
      "budgetMax": 4500,
      "categoryId": "cat_web",
      "skills": ["node", "react", "ux"]
    }
  },
  {
    "name": "proposals.list",
    "method": "GET",
    "path": "/api/proposals"
  },
  {
    "name": "proposals.create",
    "method": "POST",
    "path": "/api/proposals",
    "body": {
      "jobId": "job_benchmark",
