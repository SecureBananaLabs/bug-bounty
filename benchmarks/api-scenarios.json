      "bidAmount": 3200,
      "deliveryDays": 21
    }
  },
  {
    "name": "payments.create",
    "method": "POST",
    "path": "/api/payments",
    "body": {
      "proposalId": "prp_benchmark",
      "amount": 3200,
      "currency": "usd",
      "customerId": "cus_benchmark"
    }
  },
  {
    "name": "reviews.list",
    "method": "GET",
    "path": "/api/reviews"
  },
  {
    "name": "reviews.create",
    "method": "POST",
