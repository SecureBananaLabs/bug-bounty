# Benchmark Environment Configuration
# Copy this file to .env and adjust values for your target environment

# Target API base URL (no trailing slash)
BENCHMARK_TARGET_URL=http://localhost:3001

# Auth token for protected routes (generate a test token for benchmark user)
BENCHMARK_AUTH_TOKEN=your_benchmark_token_here

# Benchmark configuration
BENCHMARK_DURATION=30
BENCHMARK_CONNECTIONS=10
BENCHMARK_PIPELINING=1