# Benchmark Environment Configuration
# Copy this file to .env.benchmark.local and fill in your values

# Target API base URL (local or staging)
BENCHMARK_TARGET_URL=http://localhost:3001

# Benchmark token for auth-protected routes
# Create a dedicated benchmark user and use its JWT token here
BENCHMARK_TOKEN=your-benchmark-jwt-token-here

# Optional: override default benchmark duration (seconds)
BENCHMARK_DURATION=30