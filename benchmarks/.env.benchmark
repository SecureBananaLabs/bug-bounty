# Benchmark Environment Configuration
# Copy this file to .env and adjust values for your environment

# Target server URL (required)
BENCHMARK_TARGET_URL=http://localhost:3001

# Benchmark token for auth-protected routes (required for full suite)
# Create a test user and use their JWT token here
BENCHMARK_TOKEN=your-jwt-token-here

# Concurrency levels for load testing (comma-separated)
BENCHMARK_CONCURRENCY=10,50,100