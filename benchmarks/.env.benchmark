# Benchmark Configuration
# Copy this file to .env and update values for your environment

# Target API base URL (no trailing slash)
# Examples: http://localhost:3001, https://staging-api.example.com
BENCHMARK_TARGET_URL=http://localhost:3001

# Benchmark test token for auth-protected routes
# Generate a valid JWT for a benchmark/test user
BENCHMARK_AUTH_TOKEN=your-jwt-token-here

# Optional: Set to "true" to skip auth-protected routes when no token is available
BENCHMARK_SKIP_AUTH=false