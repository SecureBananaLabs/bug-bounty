# Benchmark Configuration
# Copy to .env and adjust for your environment.
# The benchmark script uses defaults for most values below.

# Server
PORT=4001

# Benchmark settings
BENCHMARK_CONNECTIONS=10
BENCHMARK_DURATION=10
BENCHMARK_PIPELINING=1

# Thresholds (overrides benchmarks/thresholds.json)
# BENCHMARK_P99_THRESHOLD=500
# BENCHMARK_ERROR_RATE=1
# BENCHMARK_MIN_RPS=50
