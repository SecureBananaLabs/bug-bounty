# Optional. When unset, benchmarks start the local Express API in-process.
BENCHMARK_TARGET_URL=http://127.0.0.1:4000

# Optional for staging targets. Local runs acquire a token through /api/auth/login.
BENCHMARK_AUTH_TOKEN=

# Full benchmark defaults are intentionally below the API rate limiter.
BENCHMARK_CONCURRENCY=4
BENCHMARK_REQUESTS_PER_ENDPOINT=8
BENCHMARK_WARMUP_REQUESTS=1
BENCHMARK_TIMEOUT_MS=5000
