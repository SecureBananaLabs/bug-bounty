# Copy this file to benchmarks/.env.benchmark for local benchmark runs.
# If BENCHMARK_BASE_URL is empty, the benchmark runner starts the local API on a random port.
BENCHMARK_BASE_URL=
BENCHMARK_AUTH_TOKEN=
BENCHMARK_DURATION_MS=2000
BENCHMARK_CONCURRENCY=4
BENCHMARK_WARMUP_REQUESTS=1
BENCHMARK_OUTPUT_DIR=benchmarks/results
