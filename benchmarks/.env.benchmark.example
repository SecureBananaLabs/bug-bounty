# benchmark env template — copy to .env.benchmark and fill in values

# Target server (default: http://localhost:3000)
BENCHMARK_HOST=http://localhost:3000

# JWT token for auth-protected routes
# Run: POST /api/auth/login → copy access_token here
BENCHMARK_TOKEN=

# Refresh token (for POST /api/auth/refresh benchmark)
BENCHMARK_REFRESH_TOKEN=

# Staging URL shortcut (used by npm run benchmark:staging)
STAGING_URL=https://staging.your-domain.com
