# Optional target. When omitted, the benchmark runner starts the local Express API in-process.
BENCHMARK_TARGET_URL=http://127.0.0.1:3000

# Optional JWT for protected benchmark routes. When omitted for local runs, a synthetic admin JWT is generated.
BENCHMARK_AUTH_TOKEN=

# Runtime controls.
BENCHMARK_CONCURRENCY=2
BENCHMARK_DURATION_SECONDS=3
BENCHMARK_MAX_REQUESTS_PER_ENDPOINT=9
BENCHMARK_TIMEOUT_MS=5000
