# Benchmark Configuration
# Copy to .env.benchmark and customize

# Target host (required)
API_BASE_URL=http://localhost:3000

# Auth token for protected endpoints (optional, set if testing protected routes)
BENCHMARK_TOKEN=

# Concurrency settings
CONCURRENCY=10
DURATION=30
CONNECTIONS=10

# CI mode: lower concurrency for fast smoke tests
CI_CONCURRENCY=2
CI_DURATION=10
