# Optional: target a running local or staging API instead of the in-process Express app.
# BENCHMARK_TARGET_URL=http://127.0.0.1:4000

# Optional: bearer token for protected routes. If omitted, local benchmarks obtain one from /api/auth/login.
# BENCHMARK_AUTH_TOKEN=replace-with-dedicated-benchmark-token

# Full-run defaults are intentionally below the API rate-limit ceiling.
BENCHMARK_REQUESTS=8
BENCHMARK_CONCURRENCY=2
BENCHMARK_WARMUP_REQUESTS=1
BENCHMARK_OUTPUT_DIR=benchmarks/results
BENCHMARK_THRESHOLDS=benchmarks/thresholds.json
