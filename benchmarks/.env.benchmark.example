# Optional. Leave BENCHMARK_TARGET_URL empty to start the local Express app.
BENCHMARK_TARGET_URL=

# Optional. Used only when benchmarking an external target that already has auth.
BENCHMARK_AUTH_TOKEN=

# Full-suite defaults can be overridden for local experiments.
BENCHMARK_DURATION_MS=1200
BENCHMARK_CONCURRENCY=4
BENCHMARK_WARMUP_REQUESTS=3

# Keep local runs below the API's default global rate limit unless explicitly disabled with 0.
BENCHMARK_MAX_REQUESTS_PER_ENDPOINT=6
