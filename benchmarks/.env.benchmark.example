# Optional target for benchmarking a running API instead of the local in-process app.
# BENCHMARK_TARGET_URL=http://127.0.0.1:4000

# Optional bearer token for protected benchmark routes when targeting staging.
# Local runs generate a benchmark admin JWT automatically.
# BENCHMARK_AUTH_TOKEN=

# Optional tuning. Defaults keep total requests under the development rate limit.
# BENCHMARK_ITERATIONS=5
# BENCHMARK_CONCURRENCY=2
# BENCHMARK_WARMUP_ITERATIONS=1
# BENCHMARK_OUTPUT_DIR=benchmarks/results
# BENCHMARK_THRESHOLDS_PATH=benchmarks/thresholds.json
