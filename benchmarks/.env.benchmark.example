NODE_ENV=benchmark
JWT_SECRET=development-secret

# Optional: benchmark an already-running API instead of starting the local app.
# BENCHMARK_TARGET_URL=http://127.0.0.1:4000

# Required when BENCHMARK_TARGET_URL points at an environment that does not use
# the local JWT_SECRET value.
# BENCHMARK_AUTH_TOKEN=

BENCHMARK_CONCURRENCY=20
BENCHMARK_REQUESTS=80
BENCHMARK_WARMUP_REQUESTS=3
BENCHMARK_TIMEOUT_MS=10000
