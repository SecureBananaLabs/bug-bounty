# Copy to .env.benchmark for local benchmark runs.
NODE_ENV=benchmark
PORT=4100
JWT_SECRET=benchmark-secret
BENCHMARK_BASE_URL=http://127.0.0.1:4100
BENCHMARK_DURATION_MS=3000
BENCHMARK_WARMUP_MS=300
BENCHMARK_CONCURRENCY=2
BENCHMARK_TIMEOUT_MS=5000
# Opt-in local/non-production benchmark bypass for the API rate limiter.
BENCHMARK_DISABLE_RATE_LIMIT=true
