# Benchmark Configuration
# Copy this file to .env.benchmark and fill in your values

# Target API host (required)
TARGET_HOST=http://localhost:3000

# Auth token for protected routes (e.g., /api/admin/metrics)
# Get this by logging in and copying the JWT access token
AUTH_TOKEN=your-jwt-token-here

# K6 runner configuration
VUS=20
DURATION=60s
ITERATIONS=

# Optional: override for specific scenarios
# VUS=5          # smoke test
# VUS=50         # load test
# VUS=100        # stress test
# DURATION=300s  # 5-minute sustained test
