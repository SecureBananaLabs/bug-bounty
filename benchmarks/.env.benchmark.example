# Optional target. Leave empty to start the local Express API in-process.
BENCHMARK_TARGET_URL=

# Smoke mode defaults are intentionally small for CI.
BENCHMARK_SMOKE_REQUESTS=4
BENCHMARK_SMOKE_CONCURRENCY=1

# Full mode defaults are still local-friendly.
BENCHMARK_REQUESTS=24
BENCHMARK_CONCURRENCY=4
BENCHMARK_WARMUP_REQUESTS=2

# Output and local API settings.
BENCHMARK_OUTPUT_DIR=benchmarks/results
BENCHMARK_RATE_LIMIT=100000
JWT_SECRET=benchmark-secret
