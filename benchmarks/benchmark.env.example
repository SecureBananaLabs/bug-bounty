BENCHMARK_BASE_URL=http://127.0.0.1:4000
BENCHMARK_CONCURRENCY=10
BENCHMARK_DURATION_MS=10000
BENCHMARK_WARMUP_MS=1000
BENCHMARK_MAX_REQUESTS_PER_ENDPOINT=
BENCHMARK_OUTPUT_DIR=benchmarks/results

# Optional. If set, auth-protected routes use this bearer token instead of
# bootstrapping one through the local auth endpoints.
BENCHMARK_TOKEN=
