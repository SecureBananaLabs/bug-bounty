# Optional. If omitted, the benchmark runner starts the local Express app.
BENCHMARK_TARGET_URL=http://127.0.0.1:4000

# Full-run defaults are 8 requests per endpoint with concurrency 4.
BENCHMARK_REQUESTS=8
BENCHMARK_CONCURRENCY=4

# Optional bearer token for protected routes when BENCHMARK_TARGET_URL points
# at a separately running API. Local runs generate a benchmark admin token.
BENCHMARK_AUTH_TOKEN=

# Used only for local benchmark runs that start the Express app.
JWT_SECRET=benchmark-secret
