# Benchmark runtime configuration
BENCHMARK_BASE_URL=
BENCHMARK_CONNECTIONS=10
BENCHMARK_DURATION_SECONDS=2
BENCHMARK_WARMUP_SECONDS=1
BENCHMARK_PIPELINING=1

# Smoke benchmark configuration used by CI
BENCHMARK_SMOKE_CONNECTIONS=2
BENCHMARK_SMOKE_DURATION_SECONDS=1
BENCHMARK_SMOKE_WARMUP_SECONDS=0

# App secrets used to build authenticated benchmark requests
JWT_SECRET=development-secret
