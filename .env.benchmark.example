# Optional external target. If omitted, the runner starts the local Express app.
# BENCHMARK_TARGET_URL=http://127.0.0.1:4000

# Optional bearer token for auth-protected benchmark routes.
# If omitted, the runner signs a benchmark-only JWT with the local JWT secret.
# BENCHMARK_AUTH_TOKEN=

# Request-shaping controls.
BENCHMARK_ITERATIONS=8
BENCHMARK_WARMUP=1
BENCHMARK_CONCURRENCY=3

# Set to smoke for low-concurrency CI gates.
# BENCHMARK_MODE=smoke
