# Optional external target. When omitted, the benchmark runner starts the API in-process.
BENCHMARK_TARGET_URL=http://127.0.0.1:4000

# Runtime controls.
BENCHMARK_DURATION_SECONDS=3
BENCHMARK_CONCURRENCY=8
BENCHMARK_WARMUP_REQUESTS=2
BENCHMARK_MAX_REQUESTS_PER_ENDPOINT=8

# Required only when BENCHMARK_TARGET_URL points at an environment whose JWT
# secret is not available locally.
BENCHMARK_AUTH_TOKEN=

# Used for locally generated benchmark auth tokens.
JWT_SECRET=benchmark-secret
