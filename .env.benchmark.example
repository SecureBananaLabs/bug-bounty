# Copy to .env.benchmark to override local benchmark defaults.
#
# When BENCHMARK_TARGET_URL is empty, the runner starts the local Express app on
# an ephemeral loopback port. Set it to benchmark an already-running local or
# staging API, for example: http://127.0.0.1:4000
BENCHMARK_TARGET_URL=

# Keep defaults modest so the suite stays below the development rate limiter.
BENCHMARK_REQUESTS_PER_ENDPOINT=6
BENCHMARK_CONCURRENCY=2
BENCHMARK_TIMEOUT_MS=5000
BENCHMARK_OUTPUT_DIR=benchmarks/results

# Used to sign benchmark-only bearer tokens for protected routes.
JWT_SECRET=development-secret
