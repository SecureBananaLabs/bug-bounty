# Benchmark Configuration
# Copy this file to .env.benchmark and adjust values for your environment

# Base URL of the API server to benchmark
BENCHMARK_URL=http://localhost:3000

# Duration in seconds to benchmark each endpoint
BENCHMARK_DURATION=10

# Number of concurrent workers per endpoint
BENCHMARK_CONCURRENCY=10

# Auth token for protected endpoints (admin/metrics)
# If not set, the benchmark will attempt to register a test user
# BENCHMARK_AUTH_TOKEN=your_jwt_token_here
