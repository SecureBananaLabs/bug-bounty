# Leave empty to let the benchmark runner start local ephemeral Express servers.
BENCHMARK_BASE_URL=

# Required only when benchmarking a staging server whose protected routes do not use the local JWT secret.
BENCHMARK_AUTH_TOKEN=

BENCHMARK_CONNECTIONS=4
BENCHMARK_REQUESTS=60
BENCHMARK_SMOKE_REQUESTS=8
BENCHMARK_TTFB_SAMPLES=5
BENCHMARK_TIMEOUT_SECONDS=10
BENCHMARK_RESULTS_DIR=benchmarks/results
BENCHMARK_THRESHOLDS_PATH=benchmarks/thresholds.json

# Internal local-run switch. Leave unset unless you know you need to override the runner default.
BENCHMARK_DISABLE_RATE_LIMIT=
