NODE_ENV=benchmark
JWT_SECRET=benchmark-secret-change-me

# Optional: run against an already deployed API instead of the in-process Express app.
# BENCHMARK_BASE_URL=https://api.example.com

# Optional authenticated-route token. When omitted, the runner signs a benchmark
# token using JWT_SECRET for protected local routes such as /api/admin/metrics.
# BENCHMARK_AUTH_TOKEN=

# Tune the local benchmark load.
BENCHMARK_DURATION_MS=10000
BENCHMARK_CONCURRENCY=8
BENCHMARK_WARMUP_REQUESTS=3
BENCHMARK_DISABLE_RATE_LIMIT=true
