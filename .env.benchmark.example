BENCHMARK_BASE_URL=http://127.0.0.1:4000
BENCHMARK_START_SERVER=true
BENCHMARK_ISOLATE_ENDPOINTS=true
BENCHMARK_DISABLE_RATE_LIMIT=true
BENCHMARK_REQUESTS_PER_ENDPOINT=100
BENCHMARK_LATENCY_SAMPLES=50
BENCHMARK_CONNECTIONS=5
BENCHMARK_PIPELINING=1
BENCHMARK_AUTH_TOKEN=
BENCHMARK_RESULTS_DIR=benchmarks/results
