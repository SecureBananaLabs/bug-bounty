# Optional. When omitted, the benchmark runner starts the Express API locally.
BENCHMARK_TARGET_URL=

# Optional. Use this when benchmarking a remote target with protected routes.
BENCHMARK_AUTH_TOKEN=

# Optional local JWT secret used for the benchmark-only admin token.
JWT_SECRET=development-secret

# Optional load controls. Defaults are low enough to avoid the local rate limiter.
BENCHMARK_REQUESTS_PER_ENDPOINT=5
BENCHMARK_CONCURRENCY=2
