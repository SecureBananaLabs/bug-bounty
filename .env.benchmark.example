# Optional. When omitted, the benchmark runner starts the local Express app.
BENCHMARK_TARGET_URL=http://127.0.0.1:4000

# Optional. Needed only when benchmarking an already-running protected target.
BENCHMARK_AUTH_TOKEN=

# Defaults are conservative for local machines and CI.
BENCHMARK_CONCURRENCY=4
BENCHMARK_REQUESTS_PER_ENDPOINT=8
BENCHMARK_TIMEOUT_MS=10000

# Local in-process benchmark runs set this automatically so handler latency is
# measured instead of express-rate-limit throttling.
BENCHMARK_DISABLE_RATE_LIMIT=true
