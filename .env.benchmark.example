# Target an already-running API. Leave unset to start the local Express app in-process.
BENCHMARK_TARGET_URL=http://127.0.0.1:4000

# JWT secret used when the benchmark runner generates the admin benchmark token.
JWT_SECRET=development-secret

# Optional explicit auth token for protected benchmark routes.
# BENCHMARK_AUTH_TOKEN=

# Load settings. Smoke mode overrides these to 1 request and 1 concurrency by default.
BENCHMARK_REQUESTS_PER_ENDPOINT=5
BENCHMARK_CONCURRENCY=2
BENCHMARK_TIMEOUT_MS=5000

# Results are written here as JSON and Markdown.
BENCHMARK_RESULTS_DIR=benchmarks/results
