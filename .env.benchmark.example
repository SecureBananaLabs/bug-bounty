# Benchmark target host (local or staging API)
BENCHMARK_TARGET=http://127.0.0.1:4000

# For local runs against the development API, this secret should match JWT_SECRET.
BENCHMARK_JWT_SECRET=development-secret

# For staging runs, prefer a short-lived token dedicated to benchmark traffic.
# BENCHMARK_AUTH_TOKEN=***

# Benchmark concurrency and load
BENCHMARK_CONNECTIONS=2
BENCHMARK_REQUESTS_PER_ENDPOINT=8
BENCHMARK_TIMEOUT_SECONDS=10
BENCHMARK_OUTPUT_DIR=benchmarks/results
