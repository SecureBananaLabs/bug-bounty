# Optional. Leave unset to let the runner start the local Express app on a random port.
BENCHMARK_TARGET_URL=http://127.0.0.1:4000

# The local runner disables API rate limiting by default so endpoint performance is measured
# rather than the rate limiter ceiling. Set this to false when benchmarking production-like
# throttling behaviour.
BENCHMARK_DISABLE_RATE_LIMIT=true

# Full benchmark defaults.
BENCHMARK_CONNECTIONS=20
BENCHMARK_DURATION_SECONDS=20
BENCHMARK_PIPELINING=1
BENCHMARK_TTFB_SAMPLES=5
BENCHMARK_TIMEOUT_MS=10000

# Smoke mode defaults are used by npm run benchmark:smoke.
BENCHMARK_SMOKE_CONNECTIONS=2
BENCHMARK_SMOKE_DURATION_SECONDS=3

# Set to false to write reports without failing on thresholds.
BENCHMARK_ENFORCE_THRESHOLDS=true
