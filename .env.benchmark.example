# Benchmark target. Leave empty to start the local Express app in-process.
BENCHMARK_TARGET_URL=

# Optional JWT for protected routes. Leave empty to generate a local benchmark token.
BENCHMARK_AUTH_TOKEN=

# Keep smoke runs cheap for CI; increase these for deeper local runs.
BENCHMARK_REQUESTS_PER_ENDPOINT=5
BENCHMARK_CONCURRENCY=2
BENCHMARK_TIMEOUT_MS=5000

# Write stable report filenames for review.
BENCHMARK_RESULT_BASENAME=latest
