{
  "name": "@freelanceflow/db",
  "version": "0.0.1",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
const assert = require('node:assert');
const { describe, it } = require('node:test');

describe('@freelanceflow/db import', () => {
  it('should be importable as a workspace package', async () => {
    const db = await import('@freelanceflow/db');
    assert.ok(db, 'package should export something');
  });
});
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "require": "./src/index.ts",
      "types": "./src/index.ts"
    }
  },
  "scripts": {
    "test": "node --test"
  },
  "dependencies": {
    "@prisma/client": "^5.0.0"
  }
}
}
