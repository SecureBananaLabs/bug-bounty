# ──────────────────────────────────────────────────
# FreelanceFlow — Environment Variables (example)
# ──────────────────────────────────────────────────
# Copy this file to `.env` and fill in your values.
#   cp .env.example .env
# ──────────────────────────────────────────────────

# ── General ──────────────────────────────────────
NODE_ENV=development
PORT=4000

# ── Authentication ───────────────────────────────
# JWT secret used to sign and verify access tokens.
# In production, use a strong random value (64+ chars).
JWT_SECRET=development-secret

# ── Database ─────────────────────────────────────
# PostgreSQL connection string used by Prisma.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=

# ── Payments (Stripe) ────────────────────────────
# Your Stripe secret key (starts with sk_live_ or sk_test_).
# Required only if using payment features.
STRIPE_SECRET_KEY=

# ── Frontend (optional, set per-app) ─────────────
# NEXT_PUBLIC_API_URL=http://localhost:4000
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
