function detectLowHangingFruit(code) {
  // Implement a simple regex or pattern to detect low hanging fruit vulnerabilities
  const regex = /(vulnerability|bug|issue|error|fault)/gi;
  const matches = code.match(regex);
  return matches ? matches.length : 0;
}
