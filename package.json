#!/usr/bin/env node

const { exec } = require('child_process');

exec('npm run benchmark', (error, stdout, stderr) => {
  if (error) {
    console.error(`Error: ${error}`);
    return;
  }
  console.log(`Benchmark execution output: ${stdout}`);
});
#!/usr/bin/env node

const { exec } = require('child_process');

exec('npm run benchmark:ci', (error, stdout, stderr) => {
  if (error) {
    console.error(`Error: ${error}`);
    return;
  }
  console.log(`Benchmark CI execution output: ${stdout}`);
});
