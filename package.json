{
  "name": "freelance-platform-monorepo",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "echo \"Run package-specific builds (e.g. npm run build -w apps/web)\"",
    "lint": "echo \"No root lint configured\"",
    "test": "npm run test -w apps/api",
"test:lint-fruit": "node --test scripts/tests/lint-fruit.test.js",
"lint-fruit": "node scripts/lint-fruit.js",
"lint-fruit:dry-run": "node scripts/lint-fruit.js --dry-run"
  }
}
