{
  "name": "freelance-platform-monorepo",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "echo \"Run package-specific builds (e.g. npm run build -w apps/web)\"",
    "lint": "echo \"No root lint configured\"",
    "benchmark": "node benchmarks/run-api-benchmark.mjs",
    "benchmark:smoke": "node benchmarks/run-api-benchmark.mjs --mode=smoke",
    "benchmark:test": "node --test benchmarks/tests/*.test.mjs",
    "test": "npm run test -w apps/api"
  },
  "devDependencies": {
    "autocannon": "^8.0.0"
  }
}
