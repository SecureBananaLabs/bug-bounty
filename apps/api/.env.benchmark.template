# Benchmark Configuration
# Copy this file to .env.benchmark and adjust values

# Target host for benchmarks
BENCHMARK_HOST=http://127.0.0.1:3000

# Test user credentials (will be auto-created)
BENCHMARK_TEST_EMAIL=benchmark@freelanceflow.test
BENCHMARK_TEST_PASSWORD=benchpass123

# Concurrency for full benchmark
BENCHMARK_CONNECTIONS=10
BENCHMARK_DURATION=10

# CI smoke test threshold (p99 latency in ms)
BENCHMARK_CI_P99_THRESHOLD=500
